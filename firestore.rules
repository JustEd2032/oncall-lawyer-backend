rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Appointments — client or lawyer of the appointment can read/write
    match /appointments/{appointmentId} {
      allow read, write: if request.auth != null && (
        resource.data.clientId == request.auth.uid ||
        resource.data.lawyerId == request.auth.uid
      );
      allow create: if request.auth != null;
    }

    // Lawyers — anyone authenticated can read, only the lawyer can write
    match /lawyers/{lawyerId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == lawyerId;
    }
  }
}